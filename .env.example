# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="ML AI Platform"
APP_VERSION="1.0.0"
DEBUG=false

# ── Auth ─────────────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys.
# Anyone calling the API must pass one of these as: X-API-Key: <key>
VALID_API_KEYS="dev-key-123,test-key-456"

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite path (relative to project root). Docker volume-mounts this directory.
DATABASE_URL="sqlite:///./data/predictions.db"

# ── ML Model ─────────────────────────────────────────────────────────────────
MODEL_PATH="ml/artifacts/model.pkl"
SCALER_PATH="ml/artifacts/scaler.pkl"
METADATA_PATH="ml/artifacts/model_metadata.json"

# ── RAG ───────────────────────────────────────────────────────────────────────
# EMBEDDING_PROVIDER: "local" (free, no key needed) or "openai" (better quality)
EMBEDDING_PROVIDER="local"

# LLM_PROVIDER: "local" (returns retrieved chunks directly) or "openai" (uses GPT)
LLM_PROVIDER="local"

# Only required if EMBEDDING_PROVIDER=openai or LLM_PROVIDER=openai
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Where the FAISS index + docstore mapping are persisted on disk
FAISS_INDEX_PATH="data/faiss_index"

# Where the source documents (knowledge base) live
DOCS_PATH="data/docs"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT="20/minute"
